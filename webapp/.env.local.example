# Copy to .env.local
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Free-tier-then-login (Google + email/password via Supabase Auth) — see webapp/README.md ---
# Both required: without them, the login page throws and the anonymous free tier still works
# (submit just never attaches a bearer token) — this feature fails closed on the auth upgrade
# only, not on the whole page. Supabase dashboard -> Project Settings -> API.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# The "anon public" key — safe to expose client-side (Supabase's RLS is the real boundary).
# NEVER use the service_role key here.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
