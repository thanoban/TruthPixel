# Copy to .env and fill in. The stub backend runs with all of these unset.

# --- App ---
APP_ENV=local
LOG_LEVEL=INFO

# --- Storage (optional in Phase 0) ---
DATABASE_URL=sqlite:///./truthpixel.db
STORAGE_BACKEND=local
LOCAL_ARTIFACT_DIR=./artifact_storage
REDIS_URL=redis://localhost:6379/0
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=truthpixel-images
S3_REGION=us-east-1

# --- Async job queue ---
CELERY_RESULT_BACKEND=
# true = run claim processing inline (no worker needed) — use for local dev
CELERY_TASK_ALWAYS_EAGER=true
WEBHOOK_TIMEOUT_SECONDS=10

# --- L5 context cross-check ---
LISTING_FETCH_TIMEOUT_SECONDS=8
LISTING_MAX_IMAGES=5
L5_RECENT_CLAIM_WINDOW=40
# Not yet read by backend/app/config.py — placeholder for Phase 1 (DINOv2/Qdrant ANN search, see ROADMAP.md L5 v1)
QDRANT_URL=http://localhost:6333
TINEYE_API_KEY=
SERPAPI_API_KEY=

# --- Models (Phase 1) ---
# L1 has three modes, in precedence order (see backend/app/analyzers/l1_aigen.py):
#   1. local trained CLIP-head checkpoint (set L1_MODEL_PATH)
#   2. HF Inference API ensemble (leave L1_MODEL_PATH empty, set HF_API_TOKEN below)
#   3. neutral stub (neither configured)
# Leave L1_MODEL_PATH empty until a checkpoint is actually trained/deployed (COLAB_TRAINING.md).
L1_MODEL_PATH=
L1_MODEL_DEVICE=auto
# L1 zero-training path: pretrained AI-image detectors called via the HF Inference API.
# Get a token at https://huggingface.co/settings/tokens (read scope is enough).
# Default models are Apache-2.0 (commercial-safe). Organika/sdxl-detector is CC-BY-NC —
# add it ONLY for non-commercial eval.
HF_API_TOKEN=
L1_HF_MODELS=Ateeqq/ai-vs-human-image-detector,Nahrawy/AIorNot
HF_INFERENCE_TIMEOUT_SECONDS=30
L2_TRUFOR_REPO_DIR=
L2_TRUFOR_MODEL_FILE=
L2_TRUFOR_PYTHON_EXECUTABLE=
L2_TRUFOR_DEVICE=-1
L2_TRUFOR_EXPERIMENT=trufor_ph3
L2_TRUFOR_TIMEOUT_SECONDS=180

# --- Vertex AI / agents (optional — stub LLM used when unset) ---
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
VERTEX_MODEL=gemini-2.0-flash
AGENT_PASS_ENABLED=true
# Agents run only when fused risk is uncertain or recapture is flagged (cost gating)
AGENT_TRIGGER_LOW=0.35
AGENT_TRIGGER_HIGH=0.85

# --- 3rd-party APIs (used by L3 recapture; optional) ---
SIGHTENGINE_API_USER=
SIGHTENGINE_API_SECRET=
SIGHTENGINE_TIMEOUT_SECONDS=15

# --- C2PA / Content Credentials (L4 metadata; optional, uses c2patool CLI) ---
C2PATOOL_PATH=c2patool
C2PATOOL_TIMEOUT_SECONDS=8
C2PATOOL_TRUST_ANCHORS=
C2PATOOL_ALLOWED_LIST=
C2PATOOL_TRUST_CONFIG=

# --- Fusion ---
# Not yet read by backend/app/config.py — placeholder for Phase 1 learned fusion (see ML_PLAN.md T2)
FUSION_MODEL_PATH=./checkpoints/fusion_meta.pkl
REVIEW_THRESHOLD=0.5

# --- Auth & rate limits ---
# false (default) = no auth at all; every request runs as an implicit "local-dev" tenant.
# Set true before exposing the API beyond localhost.
API_AUTH_ENABLED=false
# Required to use the admin endpoints (tenant/API-key management) — see backend/app/auth.py
ADMIN_API_TOKEN=
DEFAULT_TENANT_RATE_LIMIT_REQUESTS=120
DEFAULT_TENANT_RATE_LIMIT_WINDOW_SECONDS=60
# Lets POST /v1/claims accept requests with no X-API-Key (IP-rate-limited instead) —
# this is what the public webapp (webapp/) relies on. If API_AUTH_ENABLED=true and this is
# false, anonymous webapp submissions get 401 — see webapp/README.md.
PUBLIC_SUBMISSION_ENABLED=false
PUBLIC_RATE_LIMIT_REQUESTS=5
PUBLIC_RATE_LIMIT_WINDOW_SECONDS=3600

# --- CORS — public webapp + reviewer dashboard are separate origins from the API ---
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:3001
