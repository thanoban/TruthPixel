# Copy to .env and fill in. The stub backend runs with all of these unset.

# --- App ---
APP_ENV=local
LOG_LEVEL=INFO

# --- Storage (optional in Phase 0) ---
DATABASE_URL=sqlite:///./truthpixel.db
# Production (GCP Cloud Run): Supabase Postgres. Verified live 2026-07-12 against a real
# project -- these are the things that actually broke along the way, not theoretical:
#   1. Driver prefix MUST be postgresql+psycopg:// (psycopg3, what requirements.txt ships) --
#      a bare postgresql:// selects psycopg2, which is NOT installed -> ModuleNotFoundError.
#   2. Use Supabase's POOLER host (aws-0-<region>.pooler.supabase.com), not the direct host
#      (db.<project-ref>.supabase.co) -- the direct host is IPv6-only on many
#      projects/networks and will fail with "failed to resolve host" on an IPv4-only
#      network. The pooler is IPv4-compatible.
#   3. Any special character in the password MUST be percent-encoded (e.g. "@" -> "%40")
#      -- routine for a connection-string URL, but see DIRECT_URL's note below for a
#      related Alembic-specific gotcha this project already handles.
#   4. DATABASE_URL uses the pooler's TRANSACTION-mode port 6543 (Supavisor) -- Cloud Run
#      scales to many concurrent instances, each with its own DB connection, and the
#      direct/session port exhausts Postgres's connection limit fast under that pattern.
#      The app already disables psycopg3's statement autoprepare for any postgresql://
#      URL (backend/app/storage/repository.py::_engine_kwargs) -- required correctness,
#      not optional tuning: a transaction-mode pooler hands out a different backend
#      connection per transaction, so an auto-prepared statement from one transaction is
#      invalid in the next. This only bites after repeated real traffic, not on the first
#      few requests, so it won't show up in casual testing if the fix is ever reverted.
# DATABASE_URL=postgresql+psycopg://postgres.<project-ref>:<url-encoded-password>@aws-0-<region>.pooler.supabase.com:6543/postgres
# DIRECT_URL: session-mode/direct pooler connection (port 5432), used ONLY for Alembic
# migrations (backend/alembic/env.py prefers this over DATABASE_URL when set) -- DDL runs
# as one long-lived transaction, which the transaction-mode pooler above doesn't reliably
# support. Falls back to DATABASE_URL when DIRECT_URL is unset. Same driver-prefix and
# percent-encoding requirements as DATABASE_URL apply here too.
# DIRECT_URL=postgresql+psycopg://postgres.<project-ref>:<url-encoded-password>@aws-0-<region>.pooler.supabase.com:5432/postgres
STORAGE_BACKEND=local
LOCAL_ARTIFACT_DIR=./artifact_storage
REDIS_URL=redis://localhost:6379/0
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=truthpixel-images
S3_REGION=us-east-1

# --- Async job queue ---
CELERY_RESULT_BACKEND=
# true = run claim processing inline (no worker needed) — use for local dev
CELERY_TASK_ALWAYS_EAGER=true
WEBHOOK_TIMEOUT_SECONDS=10

# --- L5 context cross-check ---
LISTING_FETCH_TIMEOUT_SECONDS=8
LISTING_MAX_IMAGES=5
L5_RECENT_CLAIM_WINDOW=40
# L5 v1: blends a frozen-CLIP embedding cosine similarity into the v0 hash+histogram score.
# No training — pure inference (backend/app/embeddings.py), reuses the open_clip loader L1's
# checkpoint mode uses. Degrades to hash+histogram-only automatically if torch/open_clip_torch
# aren't installed or the model fails to load — never breaks L5.
# Defaults OFF (opt-in), matching L1/L2/L3: first use downloads the model weights over the
# network, which can hang a request on a slow/offline connection (found live — a real
# ~7-minute test-suite run and a hung demo request; see docs/CORRECTIONS.md). Turn on once
# you've pre-warmed the weights locally, e.g. `python -c "from app.embeddings import
# embed_image_bytes; embed_image_bytes(open('sample.jpg','rb').read(), model_name='ViT-B-32',
# pretrained='openai', device='cpu')"` from backend/.
L5_EMBEDDING_ENABLED=false
L5_EMBEDDING_MODEL=ViT-B-32
L5_EMBEDDING_PRETRAINED=openai
L5_EMBEDDING_DEVICE=cpu
L5_EMBEDDING_WEIGHT=0.5
# Not yet read by backend/app/config.py — placeholder for Phase 1 (Qdrant ANN search once
# claim volume makes the current linear scan over L5_RECENT_CLAIM_WINDOW too slow)
QDRANT_URL=http://localhost:6333
TINEYE_API_KEY=
SERPAPI_API_KEY=

# --- Models (Phase 1) ---
# L1 has three modes, in precedence order (see backend/app/analyzers/l1_aigen.py):
#   1. local trained CLIP-head checkpoint (set L1_MODEL_PATH)
#   2. HF Inference API ensemble (leave L1_MODEL_PATH empty, set HF_API_TOKEN below)
#   3. neutral stub (neither configured)
# Leave L1_MODEL_PATH empty until a checkpoint is actually trained/deployed (COLAB_TRAINING.md).
L1_MODEL_PATH=
L1_MODEL_DEVICE=auto
# L1 zero-training path: pretrained AI-image detectors called via the HF Inference API.
# Get a token at https://huggingface.co/settings/tokens (read scope is enough).
# Default models are Apache-2.0 (commercial-safe). Organika/sdxl-detector is CC-BY-NC —
# add it ONLY for non-commercial eval.
HF_API_TOKEN=
L1_HF_MODELS=Ateeqq/ai-vs-human-image-detector,Nahrawy/AIorNot
HF_INFERENCE_TIMEOUT_SECONDS=30
L2_TRUFOR_REPO_DIR=
L2_TRUFOR_MODEL_FILE=
L2_TRUFOR_PYTHON_EXECUTABLE=
L2_TRUFOR_DEVICE=-1
L2_TRUFOR_EXPERIMENT=trufor_ph3
L2_TRUFOR_TIMEOUT_SECONDS=180

# --- Vertex AI / agents (optional — stub LLM used when unset) ---
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
# Auth: `gcloud auth application-default login` for local dev (uses your gcloud user's ADC —
# no service-account key needed), or set GOOGLE_APPLICATION_CREDENTIALS for a deployed service.
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
# "gemini-2.0-flash" 404s as a Vertex AI publisher model (Vertex's Gemini model-name namespace
# differs from Google AI Studio's) — confirmed live 2026-07-10 against a real project.
# gemini-2.5-flash confirmed working; re-verify with `gcloud ai models list` or a live call if
# Google renames/deprecates it later.
VERTEX_MODEL=gemini-2.5-flash
AGENT_PASS_ENABLED=true
# Agents run only when fused risk is uncertain or recapture is flagged (cost gating)
AGENT_TRIGGER_LOW=0.35
AGENT_TRIGGER_HIGH=0.85

# --- 3rd-party APIs (used by L3 recapture; optional) ---
SIGHTENGINE_API_USER=
SIGHTENGINE_API_SECRET=
SIGHTENGINE_TIMEOUT_SECONDS=15

# --- C2PA / Content Credentials (L4 metadata; optional, uses c2patool CLI) ---
C2PATOOL_PATH=c2patool
C2PATOOL_TIMEOUT_SECONDS=8
C2PATOOL_TRUST_ANCHORS=
C2PATOOL_ALLOWED_LIST=
C2PATOOL_TRUST_CONFIG=

# --- Fusion ---
# Learned fusion (backend/app/fusion/learned.py) is read and wired when this is set — but the
# training/export tooling (ml/fusion/train_meta.py) needs real labeled claims data to produce
# a model; until then leave this empty and the weighted-average fallback is used (always safe).
# Exported models are JSON (ml/fusion/train_meta.py writes model.json), not .pkl.
FUSION_MODEL_PATH=
REVIEW_THRESHOLD=0.5

# --- Auth & rate limits ---
# false (default) = no auth at all; every request runs as an implicit "local-dev" tenant.
# Set true before exposing the API beyond localhost.
API_AUTH_ENABLED=false
# Required to use the admin endpoints (tenant/API-key management) — see backend/app/auth.py
ADMIN_API_TOKEN=
DEFAULT_TENANT_RATE_LIMIT_REQUESTS=120
DEFAULT_TENANT_RATE_LIMIT_WINDOW_SECONDS=60
# Lets POST /v1/claims accept requests with no X-API-Key (IP-rate-limited instead) —
# this is what the public webapp (webapp/) relies on. If API_AUTH_ENABLED=true and this is
# false, anonymous webapp submissions get 401 — see webapp/README.md.
PUBLIC_SUBMISSION_ENABLED=false
PUBLIC_RATE_LIMIT_REQUESTS=5
PUBLIC_RATE_LIMIT_WINDOW_SECONDS=3600
# Free-tier-then-login (webapp): signed-in users (Google/email via Supabase Auth) get this
# higher limit instead of the anonymous one above, scoped to their Supabase user id rather
# than IP — see backend/app/auth.py::allow_public_submission and app/supabase_auth.py.
# Requires SUPABASE_URL below; without it the bearer-token path 401s and callers should fall
# back to the anonymous path (the webapp does this automatically).
PUBLIC_USER_RATE_LIMIT_REQUESTS=25
PUBLIC_USER_RATE_LIMIT_WINDOW_SECONDS=3600
# Same Supabase project as DATABASE_URL/DIRECT_URL — used here only to verify webapp/
# dashboard Auth JWTs via JWKS (https://<ref>.supabase.co/auth/v1/.well-known/jwks.json),
# not for DB access.
# SUPABASE_URL=https://<project-ref>.supabase.co

# --- CORS — public webapp + reviewer dashboard are separate origins from the API ---
# Match backend/app/config.py defaults: both localhost and 127.0.0.1 show up in local flows.
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001
