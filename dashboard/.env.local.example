# Copy to .env.local
NEXT_PUBLIC_API_URL=http://localhost:8000

# Only needed if the backend has API_AUTH_ENABLED=true — set to a tenant API key issued via
# POST /v1/admin/tenants/{tenant_id}/api-keys. Leave unset for local dev (API_AUTH_ENABLED=false).
NEXT_PUBLIC_API_KEY=

# --- Reviewer dashboard auth (Google via Supabase Auth) — see dashboard/README.md ---
# Both required: without them, middleware.ts throws on every request (fails closed, not open).
# Supabase dashboard -> Project Settings -> API.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# The "anon public" key — safe to expose client-side (Supabase's RLS is the real boundary).
# NEVER use the service_role key here.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
