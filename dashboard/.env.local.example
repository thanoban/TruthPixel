# Copy to .env.local
# Preferred: server-side dashboard proxy target. Falls back to NEXT_PUBLIC_API_URL for backward compatibility.
TRUTHPIXEL_API_URL=http://localhost:8000

# Preferred: server-side tenant key for the reviewer dashboard proxy. Set this when the backend
# has API_AUTH_ENABLED=true. Leave unset for local dev / auth-disabled backend use.
TRUTHPIXEL_API_KEY=

# Optional pilot UX labels.
NEXT_PUBLIC_DASHBOARD_TENANT_LABEL=Reviewer workspace
NEXT_PUBLIC_DEFAULT_REVIEWER_ID=

# Legacy fallback only — not recommended for pilots because it exposes the value to the browser.
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_KEY=
